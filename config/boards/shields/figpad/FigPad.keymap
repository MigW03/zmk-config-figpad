#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

/ {
    combos {
        compatible = "zmk,combos";

        layer {
            bindings = <&sl 1>;
            key-positions = <0 1>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &kp LA(LEFT)  &kp LG(LS(S))      &kp LA(N8)    &kp LA(N9)
                &kp C_PREV  &kp C_NEXT            &kp LS(LA(V)) &kp LS(LA(H))
                &kp C_PP                          &kp LS(SPACE)
            >;
        };

        bt_layer {
            bindings = <
                &to 0         &to 2        &studio_unlock  &bootloader
                &bt BT_SEL 0  &bt BT_SEL 1  &trans  &trans
                &bt BT_SEL 2                &bt BT_CLR
            >;
        };

        mac_layer {
            bindings = <
                &kp LG(LBKT)  &kp LG(LS(N5))       &trans  &trans
                &kp C_PREV    &kp C_NEXT   &trans  &trans
                &kp C_PP                   &trans
            >;
        };
    };
};
