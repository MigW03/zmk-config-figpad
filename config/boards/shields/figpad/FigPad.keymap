#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

/ {
    combos {
        compatible = "zmk,combos";

        layer {
            bindings = <&sl 1>;
            key-positions = <0 1>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // Layer 0: everyday base / macOS mode.
        // Top-left key (position 0) is the OS-aware screenshot key. Here it
        // fires the macOS screenshot tool (Cmd+Shift+5). When the Windows
        // overlay (win_layer) is toggled on, position 0 is overridden with the
        // Windows snip command instead.
        default_layer {
            bindings = <
                &kp LG(LS(N5))  &kp LC(LS(M))      &kp LA(N8)  &kp LA(N9)
                &kp LC(LA(K))   &kp LC(LA(LS(K)))  &kp LS(LA(V))        &kp LS(LA(H))
                &kp LC(LA(B))   &kp LS(SPACE)
            >;
        };

        // Layer 1: function / Bluetooth layer (reached via the 0+1 combo).
        // Position 6 toggles the Windows OS overlay on/off (&tog 2).
        bt_layer {
            bindings = <
                &trans        &trans        &studio_unlock  &bootloader
                &bt BT_SEL 0  &bt BT_SEL 1  &tog 2          &trans
                &bt BT_SEL 2  &bt BT_CLR
            >;
        };

        // Layer 2: Windows OS overlay. Toggle on (via the function layer's
        // &tog 2) when using the Windows machine. Only the OS-specific keys are
        // remapped; everything else is &trans so the base-layer Figma shortcuts
        // still work underneath.
        //   position 0 -> Win+Shift+S (Snip & Sketch screenshot tool)
        win_layer {
            bindings = <
                &kp LG(LS(S))  &trans  &trans  &trans
                &trans         &trans  &trans  &trans
                &trans         &trans
            >;
        };
    };
};
